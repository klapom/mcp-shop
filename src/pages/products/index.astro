---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProductCard from '../../components/ProductCard.astro';
import { loadProducts } from '../../lib/products';

const products = loadProducts().filter(p => p.status !== "deprecated");
---

<Layout
  title="Produkte"
  description="Alle Knowledge-MCPs von Pommer Agents — ITIL, ServiceNow, OMNITRACKER, FNT und mehr. 14 Tage Trial, monatlich kündbar."
>
  <Header />

  <main>
    <section class="bg-[#003845] text-white py-16 px-6">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl md:text-4xl font-bold mb-4">Knowledge-Produkte</h1>
        <p class="text-white/80 text-lg max-w-2xl">
          Verbinde deinen KI-Assistenten mit deinen ITSM-Systemen.
          Jedes Produkt liefert einen dedizierten MCP-Namespace mit kontextuellen Tools.
        </p>
      </div>
    </section>

    <section class="py-16 px-6 bg-[#F4F4F8]">
      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {products.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>

        {products.length === 0 && (
          <div class="text-center py-20 text-[#6B6B8A]">
            <p class="text-lg">Produkte werden gerade vorbereitet.</p>
            <p class="text-sm mt-2">Schau bald wieder vorbei.</p>
          </div>
        )}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getToolsFor, loadNamespaces } from '../../lib/tools';
import type { NamespaceMeta, Tool, ToolProperty } from '../../lib/tools';

export function getStaticPaths() {
  const namespaces = loadNamespaces();
  return namespaces.map((ns) => ({
    params: { namespace: ns.id },
    props: { ns, tools: getToolsFor(ns.id) },
  }));
}

interface Props {
  ns: NamespaceMeta;
  tools: Tool[];
}

const { ns, tools } = Astro.props;

function formatType(prop: ToolProperty): string {
  if (Array.isArray(prop.type)) return prop.type.join(" | ");
  if (prop.type === "array" && prop.items) {
    return `${formatType(prop.items)}[]`;
  }
  return prop.type ?? "any";
}

function paramSummary(tool: Tool): { name: string; type: string; desc: string; required: boolean }[] {
  const props = tool.input_schema?.properties ?? {};
  const required = new Set(tool.input_schema?.required ?? []);
  return Object.entries(props).map(([name, p]) => ({
    name,
    type: formatType(p),
    desc: p.description ?? "",
    required: required.has(name),
  }));
}
---

<Layout
  title={`${ns.display_name} — Doku`}
  description={ns.short}
>
  <Header />

  <main>
    <!-- Breadcrumb + Hero -->
    <section class="bg-[#003845] text-white py-12 px-6">
      <div class="max-w-4xl mx-auto">
        <nav class="text-sm text-white/50 mb-6">
          <a href="/docs" class="hover:text-white transition-colors">Dokumentation</a>
          <span class="mx-2">/</span>
          <span class="text-white/80">{ns.display_name}</span>
        </nav>

        <div class="flex items-start gap-4 mb-4">
          <div class="w-14 h-14 rounded-xl bg-white/10 flex items-center justify-center text-3xl flex-shrink-0">
            {ns.icon}
          </div>
          <div>
            <h1 class="text-3xl md:text-4xl font-bold mb-1">{ns.display_name}</h1>
            <p class="text-white/80">{ns.short}</p>
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-4 mt-6 text-sm">
          <span class="font-mono text-white/80 bg-white/10 px-3 py-1 rounded">
            {ns.id}/
          </span>
          <span class="text-white/60">{tools.length} Tools</span>
        </div>
      </div>
    </section>

    <div class="max-w-5xl mx-auto px-6 py-10 grid md:grid-cols-3 gap-10">
      <!-- Main content -->
      <div class="md:col-span-2 space-y-10">
        <!-- About -->
        <section>
          <h2 class="text-xl font-bold text-[#1A1A2E] mb-3">Über diesen Namespace</h2>
          <p class="text-sm text-[#6B6B8A] leading-relaxed whitespace-pre-line">{ns.long}</p>
        </section>

        <!-- Tools -->
        <section>
          <h2 class="text-xl font-bold text-[#1A1A2E] mb-4">Tools ({tools.length})</h2>
          <div class="space-y-6">
            {tools.map((t) => {
              const params = paramSummary(t);
              const fullName = `${ns.id}_${t.name}`;
              return (
                <article id={t.name} class="bg-white rounded-xl border border-[#F4F4F8] p-5 scroll-mt-24">
                  <div class="flex items-start justify-between gap-3 mb-2">
                    <h3 class="font-mono text-[#005F73] font-bold text-base break-all">
                      {fullName}
                    </h3>
                    <span class="text-[10px] uppercase tracking-wider text-[#6B6B8A] font-semibold whitespace-nowrap">
                      {params.length === 0 ? "no args" : `${params.length} param${params.length !== 1 ? 's' : ''}`}
                    </span>
                  </div>
                  <p class="text-sm text-[#6B6B8A] leading-relaxed whitespace-pre-line mb-3">
                    {t.description || <em class="text-[#6B6B8A]/60">Keine Beschreibung verfügbar.</em>}
                  </p>
                  {params.length > 0 && (
                    <details class="mt-3">
                      <summary class="cursor-pointer text-xs font-semibold text-[#005F73] hover:text-[#E96C00] transition-colors">
                        Parameter anzeigen
                      </summary>
                      <table class="mt-3 w-full text-xs">
                        <thead class="text-[#6B6B8A] text-left">
                          <tr class="border-b border-[#F4F4F8]">
                            <th class="py-2 pr-3 font-semibold">Name</th>
                            <th class="py-2 pr-3 font-semibold">Type</th>
                            <th class="py-2 pr-3 font-semibold">Required</th>
                            <th class="py-2 font-semibold">Beschreibung</th>
                          </tr>
                        </thead>
                        <tbody>
                          {params.map((p) => (
                            <tr class="border-b border-[#F4F4F8]/50 last:border-0">
                              <td class="py-2 pr-3 font-mono text-[#1A1A2E]">{p.name}</td>
                              <td class="py-2 pr-3 font-mono text-[#005F73]">{p.type}</td>
                              <td class="py-2 pr-3">
                                {p.required ? (
                                  <span class="text-[#E96C00] font-semibold">required</span>
                                ) : (
                                  <span class="text-[#6B6B8A]">optional</span>
                                )}
                              </td>
                              <td class="py-2 text-[#6B6B8A]">{p.desc || "—"}</td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </details>
                  )}
                </article>
              );
            })}
          </div>
        </section>
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6 md:sticky md:top-6 md:self-start md:max-h-[calc(100vh-3rem)] md:overflow-y-auto">
        <div class="bg-white rounded-xl border border-[#F4F4F8] p-5">
          <h3 class="text-xs uppercase tracking-wider text-[#6B6B8A] font-semibold mb-3">
            Tools im Namespace
          </h3>
          <ul class="space-y-1 text-sm">
            {tools.map((t) => (
              <li>
                <a
                  href={`#${t.name}`}
                  class="font-mono text-[#005F73] hover:text-[#E96C00] transition-colors block py-1 break-all"
                >
                  {t.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white rounded-xl border border-[#F4F4F8] p-5">
          <h3 class="text-xs uppercase tracking-wider text-[#6B6B8A] font-semibold mb-3">
            Quellen
          </h3>
          <ul class="space-y-2 text-xs text-[#6B6B8A]">
            {ns.sources.map((s) => (
              <li class="flex gap-2">
                <span class="text-[#005F73] flex-shrink-0">•</span>
                <span>{s}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white rounded-xl border border-[#F4F4F8] p-5">
          <h3 class="text-xs uppercase tracking-wider text-[#6B6B8A] font-semibold mb-3">
            Typische Fragen
          </h3>
          <ul class="space-y-2 text-xs text-[#6B6B8A]">
            {ns.typical_questions.map((q) => (
              <li class="leading-relaxed">„{q}"</li>
            ))}
          </ul>
        </div>
      </aside>
    </div>
  </main>

  <Footer />
</Layout>
